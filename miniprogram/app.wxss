page {
  background: #f5f5f5;
  color: #1f1f1f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 16rpx;
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  background: #5b6cff;
  color: #fff;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
}

.btn--ghost {
  background: #ffffff;
  color: #5b6cff;
  border: 1rpx solid #5b6cff;
}
