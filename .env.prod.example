# 福小运 · 生产环境模板（V2.0 全量实现）
# 拷贝为 .env.prod 后填值（已被 .gitignore 屏蔽）
#
# 部署：bash scripts/deploy.sh M{milestone}
# 部署后必须验证 9+ 关键 env 已注入容器（防御 #7：.env.prod 易丢 AI_GATEWAY_API_KEY）：
#   docker compose exec qingyun env | grep -E '^(WECHAT_|AI_GATEWAY_|SESSION_)' | wc -l
# 期望 ≥ 9。

# ===== AI Gateway（必填一组）=====
# 用 ofox.ai 聚合网关（外网部署推荐；OpenAI Chat Completions 兼容）
AI_GATEWAY_BASE_URL=https://api.ofox.ai/v1
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=deepseek/deepseek-v4-pro
# 备选模型：deepseek/deepseek-v3.2、z-ai/glm-5.1、bailian/qwen3.6-plus
# 价格参考（ofox 文档 deepseek-v4-pro）：输入 $1.74/M、输出 $3.48/M、缓存读 $0.145/M

# ----- 或直连 DeepSeek（同时填会以 AI_GATEWAY_* 为准）-----
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ----- 备用 AI 网关（主网关 5xx/timeout 时自动切；non-stream 路径实装）-----
# 强烈建议生产填上至少 1 个 backup 不同厂商，避免单点故障
# 实装见 lib/ai/client.ts → tryLane("backup")
AI_GATEWAY_BACKUP_BASE_URL=
AI_GATEWAY_BACKUP_API_KEY=
AI_GATEWAY_BACKUP_MODEL=

# ===== 数据库（V2.0 单 SQLite）=====
DATABASE_URL=file:/app/data/qingyun.db

# ===== WeChat 服务号（V2.0 必填，M1 起）=====
# 申请：https://mp.weixin.qq.com/  服务号 + 企业认证
# state secret: openssl rand -base64 32
# aes key:      openssl rand -base64 32
WECHAT_APPID=
WECHAT_APPSECRET=
WECHAT_STATE_SECRET=
WECHAT_AES_KEY=
WECHAT_TPL_DAILY_FORTUNE=
WECHAT_TPL_REPORT_READY=
WECHAT_OA_REDIRECT_URI=https://qingyun.example.com/api/auth/wechat/callback

# ===== 应用（V2.0）=====
PUBLIC_BASE_URL=https://qingyun.example.com
NODE_ENV=production
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# 不允许 none，防御 #12：微信内置浏览器 SameSite=None 随机失败
SESSION_SECRET=
# session secret: openssl rand -base64 64

# ===== 限流 / 超时 =====
RATE_LIMIT_PER_HOUR_CHAT=30
RATE_LIMIT_PER_HOUR_BAZI=5
RATE_LIMIT_PER_HOUR_MEIHUA=5
RATE_LIMIT_PER_HOUR_DIVINATION=10
RATE_LIMIT_PER_HOUR_DREAM=10
AI_TIMEOUT_MS=60000
# 防御 #2：30s 太紧八字/梅花会超时

# ===== Cron（V2.0，时区 Asia/Shanghai）=====
# 1=启用调度（prod 默认开），0=禁用（用于无任务的 worker 实例）
CRON_ENABLED=1
CRON_DAILY_FORTUNE=30 0 * * *
CRON_WEEKLY_FORTUNE=0 1 * * 1
CRON_MONTHLY_FORTUNE=30 1 1 * *
CRON_TZ=Asia/Shanghai

# ===== KV Store（OTP / rate-limit）=====
# 单实例 memory 够用；多副本上线必须切 redis（实现见 lib/cache/kv-store.ts）
KV_STORE=memory
# REDIS_URL=redis://default:password@redis-host:6379/0

# ===== SMS（必填，短信验证码）=====
# 控制台：https://console.cloud.tencent.com/smsv2
# 内测期短信通道还没接通时：SMS_PROVIDER=mock + SMS_MOCK_LOG=1
# 这样验证码会在 docker compose logs 里以 [sms:mock:beta] 行打出来，正式上线务必改回 tencent + 删 SMS_MOCK_LOG
SMS_PROVIDER=tencent
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID_OTP=
# Prod 强制忽略 MOCK_OTP_BYPASS（lib/auth/phone-otp.ts 内置防御）

# ===== 八字 / 梅花 Provider 切换 =====
BAZI_PROVIDER=local
MEIHUA_PROVIDER=local

# ===== 微信小程序登录（M5+ 启用）=====
# 申请：https://mp.weixin.qq.com/  小程序 + 同主体绑定到 WECHAT_APPID 同一开放平台（用 unionid 合并 H5 老账号）
WECHAT_MINI_APPID=
WECHAT_MINI_APPSECRET=

# ===== 监控（Sentry，2026-05-07 启用）=====
# SENTRY_DSN：服务端（Node + Edge runtime，instrumentation.ts 调 initSentry）
# NEXT_PUBLIC_SENTRY_DSN：客户端（instrumentation-client.ts + global-error.tsx 上报）
# 一般填同一个 project DSN 两次即可
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# 0..1.0 的 traces 采样率（开 trace 才有性能数据；内测期 0.1 足够）
SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE=0
LOG_LEVEL=info

# ===== Email（反馈 / 系统通知）=====
# console = 仅 console 打日志（dev/默认）；smtp = 走 SMTP 网关
EMAIL_PROVIDER=console
EMAIL_FROM="福小运 <feedback@qingyun-ai.com>"
FEEDBACK_EMAIL_TO=feedback@qingyun-ai.com
# 启用 SMTP 时填：
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_SECURE=1
# SMTP_USER=
# SMTP_PASS=

# ===== 兼容 V1.0 字段（保留，可删）=====
RATE_LIMIT_PER_USER_HOURLY=30
NEXT_PUBLIC_APP_NAME=福小运
