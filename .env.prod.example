# 轻运 AI · 生产环境模板
# 拷贝为 .env.prod 后填值（已被 .gitignore 屏蔽）
#
# 部署：bash deploy.sh

# ===== AI Gateway（必填一组）=====
# 用 ofoai 聚合网关（推荐外网部署）
AI_GATEWAY_BASE_URL=https://api.ofoai.com/v1
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=deepseek-chat

# ----- 或直连 DeepSeek（同时填会以 AI_GATEWAY_* 为准）-----
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ===== 限流 / 超时 =====
RATE_LIMIT_PER_USER_HOURLY=30
AI_TIMEOUT_MS=30000

# ===== 应用 =====
NEXT_PUBLIC_APP_NAME=轻运AI
