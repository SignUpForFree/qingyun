# 轻运 AI · 生产环境模板
# 拷贝为 .env.prod 后填值（已被 .gitignore 屏蔽）
#
# 部署：bash deploy.sh

# ===== AI Gateway（必填一组）=====
# 用 ofox.ai 聚合网关（外网部署推荐；OpenAI Chat Completions 兼容）
AI_GATEWAY_BASE_URL=https://api.ofox.ai/v1
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=deepseek/deepseek-v4-pro
# 备选模型：deepseek/deepseek-v3.2、z-ai/glm-5.1、bailian/qwen3.6-plus
# 价格参考（ofox 文档 deepseek-v4-pro）：输入 $1.74/M、输出 $3.48/M、缓存读 $0.145/M

# ----- 或直连 DeepSeek（同时填会以 AI_GATEWAY_* 为准）-----
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ===== 限流 / 超时 =====
RATE_LIMIT_PER_USER_HOURLY=30
AI_TIMEOUT_MS=30000

# ===== 应用 =====
NEXT_PUBLIC_APP_NAME=轻运AI
