# 轻运 AI · 生产环境模板（V2.0 全量实现）
# 拷贝为 .env.prod 后填值（已被 .gitignore 屏蔽）
#
# 部署：bash scripts/deploy.sh M{milestone}
# 部署后必须验证 9+ 关键 env 已注入容器（防御 #7：.env.prod 易丢 AI_GATEWAY_API_KEY）：
#   docker compose exec qingyun env | grep -E '^(WECHAT_|AI_GATEWAY_|SESSION_)' | wc -l
# 期望 ≥ 9。

# ===== AI Gateway（必填一组）=====
# 用 ofox.ai 聚合网关（外网部署推荐；OpenAI Chat Completions 兼容）
AI_GATEWAY_BASE_URL=https://api.ofox.ai/v1
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=deepseek/deepseek-v4-pro
# 备选模型：deepseek/deepseek-v3.2、z-ai/glm-5.1、bailian/qwen3.6-plus
# 价格参考（ofox 文档 deepseek-v4-pro）：输入 $1.74/M、输出 $3.48/M、缓存读 $0.145/M

# ----- 或直连 DeepSeek（同时填会以 AI_GATEWAY_* 为准）-----
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ----- 备用 AI 网关（M5.17，主网关 5xx/timeout 时切；可选）-----
# AI_GATEWAY_BACKUP_BASE_URL=
# AI_GATEWAY_BACKUP_API_KEY=
# AI_GATEWAY_BACKUP_MODEL=

# ===== 数据库（V2.0 单 SQLite）=====
DATABASE_URL=file:/app/data/qingyun.db

# ===== WeChat 服务号（V2.0 必填，M1 起）=====
# 申请：https://mp.weixin.qq.com/  服务号 + 企业认证
# state secret: openssl rand -base64 32
# aes key:      openssl rand -base64 32
WECHAT_APPID=
WECHAT_APPSECRET=
WECHAT_STATE_SECRET=
WECHAT_AES_KEY=
WECHAT_TPL_DAILY_FORTUNE=
WECHAT_TPL_REPORT_READY=
WECHAT_OA_REDIRECT_URI=https://qingyun.example.com/api/auth/wechat/callback

# ===== 应用（V2.0）=====
PUBLIC_BASE_URL=https://qingyun.example.com
NODE_ENV=production
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# 不允许 none，防御 #12：微信内置浏览器 SameSite=None 随机失败
SESSION_SECRET=
# session secret: openssl rand -base64 64

# ===== 限流 / 超时 =====
RATE_LIMIT_PER_HOUR_CHAT=30
RATE_LIMIT_PER_HOUR_BAZI=5
RATE_LIMIT_PER_HOUR_MEIHUA=5
RATE_LIMIT_PER_HOUR_DIVINATION=10
RATE_LIMIT_PER_HOUR_DREAM=10
AI_TIMEOUT_MS=60000
# 防御 #2：30s 太紧八字/梅花会超时

# ===== Cron（V2.0，时区 Asia/Shanghai）=====
CRON_DAILY_FORTUNE=30 0 * * *
CRON_WEEKLY_FORTUNE=0 1 * * 1
CRON_MONTHLY_FORTUNE=30 1 1 * *
CRON_TZ=Asia/Shanghai

# ===== 监控（M5.16）=====
# SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=info

# ===== 兼容 V1.0 字段（保留，可删）=====
RATE_LIMIT_PER_USER_HOURLY=30
NEXT_PUBLIC_APP_NAME=轻运AI
