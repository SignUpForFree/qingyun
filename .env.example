# 轻运 AI · 环境变量模板
# 复制为 .env.local（已被 .gitignore 屏蔽）后填入真实值

# ===== 本地数据库 (SQLite) =====
# 默认 file:./dev.db；改为 :memory: 让数据每次重启清空
# proxy.ts + lib/db/client.ts 自动 migrate，第一次跑 dev 自动建好 dev.db
DATABASE_URL=file:./dev.db

# ===== AI Gateway（OpenAI 兼容；ofoai / one-api / openrouter / 自建代理通用）=====
# 切上游只改这 3 个变量；优先级高于 DEEPSEEK_* fallback
#
# 用 ofoai 聚合网关示例：
#   AI_GATEWAY_BASE_URL=https://api.ofoai.com/v1
#   AI_GATEWAY_API_KEY=sk-xxxxxxxxxxxx
#   AI_GATEWAY_MODEL=deepseek-chat            # 或网关支持的其它模型名
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=deepseek-chat

# ----- 兼容老配置（直连 DeepSeek 官方时填这一组）-----
# 与 AI_GATEWAY_* 二选一；同时填了以 AI_GATEWAY_* 为准
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== 限流 / 超时 =====
RATE_LIMIT_PER_USER_HOURLY=30
AI_TIMEOUT_MS=30000

# ===== 应用 =====
NEXT_PUBLIC_APP_NAME=轻运AI
NODE_ENV=development
