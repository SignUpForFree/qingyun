# 轻运 AI · 环境变量模板
# 复制为 .env.local（已被 .gitignore 屏蔽）后填入真实值

# ===== 本地数据库 (SQLite) =====
# 默认 file:./dev.db, 也可改为 :memory: 让数据每次重启清空
# proxy.ts + lib/db/client.ts 自动 migrate, 第一次跑 dev 会自动建好 dev.db
DATABASE_URL=file:./dev.db

# ===== DeepSeek (W2 真要跑流式时必填; 单测 mock 不需要) =====
# 注册 https://platform.deepseek.com 后从 API Keys 取
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== AI Gateway 限流 =====
RATE_LIMIT_PER_USER_HOURLY=30
AI_TIMEOUT_MS=30000

# ===== 应用 =====
NEXT_PUBLIC_APP_NAME=轻运AI
NODE_ENV=development
