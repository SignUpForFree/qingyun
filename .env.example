# 福小运 · 环境变量模板
# 复制为 .env.local（已被 .gitignore 屏蔽）后填入真实值

# ===== 本地数据库 (SQLite) =====
# 默认 file:./dev.db；改为 :memory: 让数据每次重启清空
# proxy.ts + lib/db/client.ts 自动 migrate，第一次跑 dev 自动建好 dev.db
DATABASE_URL=file:./dev.db

# ===== AI Gateway（OpenAI 兼容；ofox / one-api / openrouter / 自建代理通用）=====
# 切上游只改这 3 个变量；优先级高于 DEEPSEEK_* fallback
#
# 用 ofox.ai 聚合网关示例（OpenAI Chat Completions 兼容）：
#   AI_GATEWAY_BASE_URL=https://api.ofox.ai/v1
#   AI_GATEWAY_API_KEY=sk-of-xxxxxxxxxxxx
#   AI_GATEWAY_MODEL=deepseek/deepseek-v4-pro   # provider/model 命名空间
#   备选模型：deepseek/deepseek-v3.2、z-ai/glm-5.1、bailian/qwen3.6-plus
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=deepseek/deepseek-v4-pro

# ----- 兼容老配置（直连 DeepSeek 官方时填这一组）-----
# 与 AI_GATEWAY_* 二选一；同时填了以 AI_GATEWAY_* 为准
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== 限流 / 超时 =====
RATE_LIMIT_PER_USER_HOURLY=30
AI_TIMEOUT_MS=30000

# ===== KV Store（OTP / rate-limit）=====
# memory：进程内 Map（dev / 单容器够用）；redis：上线后切（lib/cache/kv-store.ts 待实现）
KV_STORE=memory

# ===== SMS（短信验证码）=====
# 默认 dev=mock（console.info 打 OTP），prod=tencent
SMS_PROVIDER=mock
# tencent 模式必填（dev 用 mock 时可不填）：
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID_OTP=
# dev 任何 6 位数字都通过；prod 强制忽略此 env
MOCK_OTP_BYPASS=1

# ===== 八字 / 梅花 Provider 切换 =====
# local：本地纯 TS 算法库（lib/bazi、lib/divination）
# api：占位（lib/divination-providers/{bazi,meihua}.ts 中 RemoteApiXxxProvider 待实现）
BAZI_PROVIDER=local
MEIHUA_PROVIDER=local

# ===== Cron 调度 =====
# 1=启用，0=禁用；默认：dev 关 / prod 开
CRON_ENABLED=0
CRON_TZ=Asia/Shanghai

# ===== 微信小程序登录（可选，M5+）=====
# WECHAT_MINI_APPID=
# WECHAT_MINI_APPSECRET=

# ===== 备用 AI 网关（主网关 5xx/timeout 自动切；可选）=====
# AI_GATEWAY_BACKUP_BASE_URL=
# AI_GATEWAY_BACKUP_API_KEY=
# AI_GATEWAY_BACKUP_MODEL=

# ===== Sentry（错误聚合，2026-05-07）=====
# 服务端 / 客户端可配同一个 DSN；缺省 = no-op
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# ===== Email（反馈 / 通知）=====
# console = 打日志（默认）；smtp = 走 SMTP（需 nodemailer）
EMAIL_PROVIDER=console
# EMAIL_FROM="福小运 <feedback@example.com>"
# FEEDBACK_EMAIL_TO=feedback@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_SECURE=1
# SMTP_USER=
# SMTP_PASS=

# ===== 应用 =====
NEXT_PUBLIC_APP_NAME=福小运
NODE_ENV=development
# JWT 签名 key（签 Bearer token）；生产请用 openssl rand -base64 64
SESSION_SECRET=
