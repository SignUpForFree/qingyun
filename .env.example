# 轻运 AI · 环境变量模板
# 复制为 .env.local（已被 .gitignore 屏蔽）后填入真实值
# W1 D1-D5 (A/S/C/D/E task) 不需要任何真实 key, 全部留空也能跑

# ===== Supabase (W2 起需要) =====
# 注册 supabase.com (5 min 免费, 无信用卡), 新建项目后从 Settings > API 复制
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== DeepSeek (P1 单测全 mock 不需要; W2 想验证流式时再填) =====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== AI Gateway 限流 =====
AI_RATE_LIMIT_PER_MINUTE=10
AI_RATE_LIMIT_PER_DAY=100
AI_TIMEOUT_MS=30000

# ===== 应用 =====
NEXT_PUBLIC_APP_NAME=轻运AI
NODE_ENV=development
