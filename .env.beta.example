# ==============================================================================
# 福小运 · 内测最小 .env.prod 模板（2026-05-08）
# ------------------------------------------------------------------------------
# 用法：scp 到服务器后 mv .env.beta.example .env.prod，再填 3 个必填字段：
#   1) AI_GATEWAY_API_KEY      （ofox.ai 控制台拿）
#   2) SESSION_SECRET          （在终端执行 openssl rand -base64 64 把输出粘贴进来）
#   3) PUBLIC_BASE_URL         （http://你的服务器IP:3000）
#
# 内测期暂时跳过的：
#   · SMS（手机号 OTP）：等审核完再填 TENCENT_SMS_*
#   · 微信公众号 OAuth：等 ICP 备案 + 公众号 H5 域名审核完再填 WECHAT_*
#   · 微信小程序：等审核
#   · Sentry：填 DSN 才上报，不填就 no-op
#
# 内测登录方式：用 BETA_DEV_LOGIN=1 + curl 拿 cookie，详见 docs/未完成.txt
# ==============================================================================

# ===== AI 网关（必填）=====
AI_GATEWAY_BASE_URL=https://api.ofox.ai/v1
AI_GATEWAY_API_KEY=sk-5df581ec33394eb1bc4a091254904e9d
AI_GATEWAY_MODEL=deepseek/deepseek-v4-pro

# ===== 应用 =====
PUBLIC_BASE_URL=http://YOUR_SERVER_IP:3000
NODE_ENV=production
DATABASE_URL=file:/app/data/qingyun.db

# ===== Cookie / Session（必填 SESSION_SECRET）=====
# 走 http 直连 IP 时 secure 必须 false；上 https 后改 true
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
SESSION_SECRET=

# ===== 内测专用：在 prod 里允许 /api/dev-login，免 SMS 也能登录 =====
# 真上线（SMS 接好后）一定要去掉这一行！
BETA_DEV_LOGIN=1

# ===== AI 超时（八字 / 梅花需要 60s）=====
AI_TIMEOUT_MS=60000

# ===== 限流（内测人少，给宽松点）=====
RATE_LIMIT_PER_HOUR_CHAT=100
RATE_LIMIT_PER_HOUR_BAZI=20
RATE_LIMIT_PER_HOUR_MEIHUA=20
RATE_LIMIT_PER_HOUR_DIVINATION=30
RATE_LIMIT_PER_HOUR_DREAM=30

# ===== Cron（内测期关掉，避免每天给假用户 push）=====
CRON_ENABLED=0

# ===== KV 单机内存够用 =====
KV_STORE=memory

# ===== 其余可选（先空着）=====
# 短信：内测期不接腾讯云，让 mock provider 把验证码打到容器日志里
# 真上线接通腾讯云后改 SMS_PROVIDER=tencent 并删掉 SMS_MOCK_LOG
SMS_PROVIDER=mock
SMS_MOCK_LOG=1
EMAIL_PROVIDER=console
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
BAZI_PROVIDER=local
MEIHUA_PROVIDER=local
